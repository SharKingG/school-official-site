generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminStatus {
  ENABLED
  DISABLED
}

enum CategoryStatus {
  ENABLED
  DISABLED
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  OFFLINE
}

enum ArticleType {
  NORMAL
  EXTERNAL_LINK
}

enum CommonStatus {
  ENABLED
  DISABLED
}

model AdminUser {
  id           Int         @id @default(autoincrement())
  username     String      @unique
  passwordHash String
  nickname     String
  role         String      @default("SUPER_ADMIN")
  status       AdminStatus @default(ENABLED)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  articles Article[] @relation("ArticleCreator")
  operationLogs OperationLog[] @relation("OperationLogUser")
  reviewLogs ArticleReviewLog[] @relation("ArticleReviewUser")

  @@map("admin_users")
}

model Category {
  id        Int            @id @default(autoincrement())
  name      String
  slug      String         @unique
  parentId  Int?
  sort      Int            @default(0)
  status    CategoryStatus @default(ENABLED)
  type      String         @default("ARTICLE")
  path      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  articles Article[]

  @@index([parentId])
  @@map("categories")
}

model Article {
  id          Int           @id @default(autoincrement())
  title       String
  summary     String?       @db.VarChar(500)
  content     String        @db.LongText
  categoryId  Int
  author      String?
  source      String?
  department  String?
  type        ArticleType   @default(NORMAL)
  status      ArticleStatus @default(DRAFT)
  linkUrl     String?       @db.VarChar(500)
  coverImage  String?       @db.VarChar(500)
  listImage   String?       @db.VarChar(500)
  headImage   String?       @db.VarChar(500)
  isTop       Boolean       @default(false)
  sort        Int           @default(0)
  viewCount   Int           @default(0)
  publishedAt DateTime?
  creatorId   Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category Category      @relation(fields: [categoryId], references: [id])
  creator  AdminUser?    @relation("ArticleCreator", fields: [creatorId], references: [id])
  files    ArticleFile[]
  reviewLogs ArticleReviewLog[]

  @@index([categoryId])
  @@index([status])
  @@index([isTop])
  @@index([publishedAt])
  @@map("articles")
}

model ArticleFile {
  id        Int      @id @default(autoincrement())
  articleId Int
  fileName  String
  fileUrl   String   @db.VarChar(500)
  fileSize  Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("article_files")
}

model Banner {
  id        Int          @id @default(autoincrement())
  title     String
  subtitle  String?      @db.VarChar(500)
  imageUrl  String       @db.VarChar(500)
  linkUrl   String?      @db.VarChar(500)
  position  String       @default("HOME_TOP")
  size      String?      @db.VarChar(100)
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([position])
  @@index([status])
  @@map("banners")
}

model LinkItem {
  id         Int          @id @default(autoincrement())
  name       String
  url        String       @db.VarChar(500)
  category   String       @default("QUICK_LINK")
  type       String       @default("INTERNAL")
  openTarget String       @default("SELF")
  icon       String?      @db.VarChar(50)
  sort       Int          @default(0)
  status     CommonStatus @default(ENABLED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([category])
  @@index([status])
  @@map("links")
}

model Leader {
  id        Int          @id @default(autoincrement())
  name      String
  title     String
  photo     String?      @db.VarChar(500)
  intro     String?      @db.Text
  sort      Int          @default(0)
  status    CommonStatus @default(ENABLED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@map("leaders")
}

model UploadFile {
  id           Int      @id @default(autoincrement())
  originalName String
  fileName     String
  fileUrl      String   @db.VarChar(500)
  fileSize     Int      @default(0)
  mimeType     String?
  module       String   @default("common")
  createdAt    DateTime @default(now())

  @@index([module])
  @@map("upload_files")
}

model AdmissionPlan {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.LongText
  target      String?      @db.VarChar(200)
  startTime   DateTime?
  endTime     DateTime?
  contact     String?      @db.VarChar(200)
  attachment  String?      @db.VarChar(500)
  sort        Int          @default(0)
  status      CommonStatus @default(ENABLED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  records AdmissionRecord[]

  @@index([status])
  @@map("admission_plans")
}

model AdmissionRecord {
  id          Int      @id @default(autoincrement())
  planId      Int
  studentName String
  gender      String?  @db.VarChar(20)
  idCard      String   @db.VarChar(50)
  phone       String   @db.VarChar(50)
  school      String?  @db.VarChar(200)
  grade       String?  @db.VarChar(100)
  score       String?  @db.VarChar(100)
  remark      String?  @db.Text
  status      String   @default("SUBMITTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan AdmissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([studentName])
  @@index([idCard])
  @@map("admission_records")
}

model RecruitmentPlan {
  id            Int          @id @default(autoincrement())
  title         String
  department    String?      @db.VarChar(200)
  positionCount Int          @default(1)
  description   String?      @db.LongText
  requirements  String?      @db.LongText
  startTime     DateTime?
  endTime       DateTime?
  contact       String?      @db.VarChar(200)
  attachment    String?      @db.VarChar(500)
  sort          Int          @default(0)
  status        CommonStatus @default(ENABLED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  records RecruitmentRecord[]

  @@index([status])
  @@map("recruitment_plans")
}

model RecruitmentRecord {
  id            Int      @id @default(autoincrement())
  planId        Int
  applicantName String
  gender        String?  @db.VarChar(20)
  phone         String   @db.VarChar(50)
  email         String?  @db.VarChar(200)
  education     String?  @db.VarChar(100)
  major         String?  @db.VarChar(200)
  attachmentUrl String?  @db.VarChar(500)
  remark        String?  @db.Text
  status        String   @default("SUBMITTED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plan RecruitmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([applicantName])
  @@map("recruitment_records")
}

model QueryProject {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  queryFields String       @default("name,idCard") @db.VarChar(200)
  sort        Int          @default(0)
  status      CommonStatus @default(ENABLED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  records QueryRecord[]

  @@index([status])
  @@map("query_projects")
}

model QueryRecord {
  id            Int      @id @default(autoincrement())
  projectId     Int
  name          String
  idCard        String?  @db.VarChar(50)
  ticketNo      String?  @db.VarChar(100)
  resultTitle   String
  resultContent String?  @db.LongText
  fileUrl       String?  @db.VarChar(500)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project QueryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([name])
  @@index([idCard])
  @@index([ticketNo])
  @@map("query_records")
}


model Role {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?      @db.VarChar(500)
  permissions String       @db.Text
  sort        Int          @default(0)
  status      CommonStatus @default(ENABLED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@map("roles")
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  username    String?  @db.VarChar(100)
  module      String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  targetType  String?  @db.VarChar(100)
  targetId    Int?
  description String?  @db.VarChar(1000)
  result      String   @default("SUCCESS") @db.VarChar(50)
  ip          String?  @db.VarChar(100)
  createdAt   DateTime @default(now())

  user AdminUser? @relation("OperationLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model ArticleReviewLog {
  id           Int      @id @default(autoincrement())
  articleId    Int
  reviewerId   Int?
  reviewerName String?  @db.VarChar(100)
  action       String   @db.VarChar(100)
  fromStatus   String?  @db.VarChar(50)
  toStatus     String?  @db.VarChar(50)
  comment      String?  @db.VarChar(1000)
  createdAt    DateTime @default(now())

  article  Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewer AdminUser? @relation("ArticleReviewUser", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@index([reviewerId])
  @@index([createdAt])
  @@map("article_review_logs")
}
